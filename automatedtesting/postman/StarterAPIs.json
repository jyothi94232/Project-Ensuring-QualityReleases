						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/Activities",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"Activities"
							]
						}
					},
					"response": []
				},
